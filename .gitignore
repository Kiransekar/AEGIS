firmware/*.elf
firmware/*.bin
firmware/*.map

# OS files
.DS_Store
*.swp
*.swo
*~

# PDK (large, cloned separately)
skywater-pdk/
third_party/skywater-pdk/

# External tools (large, cloned/built separately)
SymbiYosys/
