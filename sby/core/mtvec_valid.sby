[options]
mode bmc
depth 10

[script]
read_verilog -sv ../../rtl/core/rt_exception_handler.v
prep -top rt_exception_handler

[files]
../../rtl/core/rt_exception_handler.v

[engines]
smtbmc z3

[tasks]
mtvec_alignment
    assert property (@(posedge i_clk) disable iff (!i_rst_n))
        o_mtvec[1:0] == 2'b00;

mtvec_accessible
    assert property (@(posedge i_clk) disable iff (!i_rst_n))
        i_mtvec_we |-> o_mtvec[31:2] != 0;

mtvec_mode_valid
    assert property (@(posedge i_clk) disable iff (!i_rst_n))
        o_mtvec[1:0] inside {2'b00, 2'b01};
