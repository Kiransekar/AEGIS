-		--build \
-		-CFLAGS "-I. -I$(TB_DIR) -std=c++17" \
-		-LDFLAGS "-lpthread" || exit 1; \
+	iverilog -g2012 -Irtl/security \
+		-DSAFETY_MODE -DSIMULATION \
+		$(if $(filter 1,$(TRACE)),-DTRACE) \
+		-o $(SIM_DIR)/$*_sim \
+		-f $(RTL_LIST) $(TB_DIR)/tb_memory_model.v $$tb_file || exit 1; \
 	echo "[→] Running: $*"; \
-	$(SIM_DIR)/$*_obj/V$*_tb $(if $(TEST),+test=$(TEST)); \
-	echo "[✓] Simulation complete: $*"
+	vvp $(SIM_DIR)/$*_sim $(if $(TEST),+test=$(TEST)) 2>&1 | tee $(SIM_DIR)/$*.log; \
+	if grep -qE '\[FAIL|FAIL:|Some tests failed' $(SIM_DIR)/$*.log; then \
+		echo "[✗] Simulation FAILED: $*"; exit 1; \
+	fi; \
+	echo "[✓] Simulation passed: $*"
 
