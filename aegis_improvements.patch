diff --git a/.github/workflows/ci.yml b/.github/workflows/ci.yml
new file mode 100644
index 0000000..5795611
--- /dev/null
+++ b/.github/workflows/ci.yml
@@ -0,0 +1,71 @@
+#===============================================================================
+# AEGIS-RV Continuous Integration
+# Runs on every push and pull request:
+#   1. Verilator lint (structural quality gate)
+#   2. Icarus Verilog unit test suite (functional gate)
+#   3. Integration tests (smoke, fault injection, WCET)
+#===============================================================================
+name: CI
+
+on:
+  push:
+    branches: [master, main]
+  pull_request:
+
+jobs:
+  lint:
+    name: Verilator Lint
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v4
+      - name: Install Verilator
+        run: sudo apt-get update && sudo apt-get install -y verilator
+      - name: Lint RTL
+        # Warnings are reported but do not fail the build yet.
+        # Once the warning count reaches zero, remove '|| true' to
+        # enforce a zero-warning policy (expected for safety cert).
+        run: |
+          verilator --lint-only -Wall -Irtl/security -f rtl/rtl_list.f 2>&1 \
+            | tee lint.log || true
+          echo "### Lint summary" >> "$GITHUB_STEP_SUMMARY"
+          grep -E "^%(Warning|Error)" lint.log | awk -F: '{print $1}' \
+            | sort | uniq -c | sort -rn >> "$GITHUB_STEP_SUMMARY" || true
+      - name: Fail on hard errors
+        run: "! grep -qE '^%Error(-[A-Z]+)?:' lint.log"
+      - uses: actions/upload-artifact@v4
+        with:
+          name: lint-log
+          path: lint.log
+
+  sim:
+    name: Unit Tests (Icarus Verilog)
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v4
+      - name: Install Icarus Verilog
+        run: sudo apt-get update && sudo apt-get install -y iverilog
+      - name: Run unit test suite
+        run: make sim
+      - name: Run integration tests
+        run: make sim_integration
+      - uses: actions/upload-artifact@v4
+        if: always()
+        with:
+          name: sim-logs
+          path: sim/*.log
+
+  formal:
+    name: Formal Verification (SymbiYosys)
+    runs-on: ubuntu-latest
+    # Formal proofs can be long-running; keep them on master pushes only.
+    if: github.event_name == 'push'
+    continue-on-error: true
+    steps:
+      - uses: actions/checkout@v4
+      - name: Install OSS CAD Suite (sby + solvers)
+        run: |
+          curl -sL https://github.com/YosysHQ/oss-cad-suite-build/releases/download/2024-06-14/oss-cad-suite-linux-x64-20240614.tgz \
+            | tar xz
+          echo "$PWD/oss-cad-suite/bin" >> "$GITHUB_PATH"
+      - name: Run formal properties
+        run: make formal
